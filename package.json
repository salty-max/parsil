{
  "name": "parsil",
  "version": "2.2.0",
  "description": "A parser combinators library written in Typescript",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/salty-max/parsil.git"
  },
  "author": "Maxime Blanc <max@jellycat.fr>",
  "license": "MIT",
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "clean": "rimraf dist",
    "build:esm": "bun build src/index.ts --outdir dist --sourcemap --minify --target=browser --format=esm",
    "build:types": "tsc --emitDeclarationOnly -p tsconfig.json && tsc-alias -p tsconfig.json",
    "build": "bun run clean && bun run build:esm && bun run build:types",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.tests.json --noEmit",
    "test": "bun test",
    "lint": "bunx eslint . --max-warnings 0",
    "lint:fix": "bunx eslint . --fix --max-warnings 0",
    "format": "bunx prettier . -w",
    "knip:check": "bunx knip",
    "commitlint": "bunx commitlint --edit",
    "changeset": "bunx changeset",
    "changeset:status": "bunx changeset status --since=origin/main",
    "changeset:version": "bunx changeset version",
    "changeset:tag": "bunx changeset tag",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@types/node": "^25.6.1",
    "bun-types": "^1.3.13",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "husky": "^9.1.7",
    "knip": "^6.12.1",
    "lint-staged": "^17.0.2",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tsc-alias": "^1.8.17",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  },
  "engines": {
    "node": ">=20",
    "bun": ">=1.1"
  },
  "keywords": [
    "parser",
    "parser-combinator",
    "combinators",
    "parsing",
    "functional",
    "typescript",
    "esm",
    "utf8",
    "binary",
    "bit",
    "dataview",
    "grammar",
    "peg",
    "bnf"
  ]
}
